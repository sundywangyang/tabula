{
  "name": "tabula",
  "version": "0.1.0",
  "private": true,
  "main": "out/main/index.js",
  "description": "Tabula - Windows file manager with tabs and split panes",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build && node scripts/build-ext-host.cjs",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "package": "electron-vite build && node scripts/build-ext-host.cjs && electron-builder",
    "package:dir": "electron-vite build && node scripts/build-ext-host.cjs && electron-builder --dir"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  },
  "dependencies": {
    "@tabula/bridge": "workspace:*",
    "@tabula/core": "workspace:*",
    "@tabula/ext-api": "workspace:*",
    "@tabula/ui": "workspace:*"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}
